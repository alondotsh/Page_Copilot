{
  "manifest_version": 3,
  "name": "Page Copilot by Alon",
  "version": "1.1.0",
  "description": "Compare webpages and videos across tabs with AI, then summarize and ask follow-up questions with your own API key.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["video-transcript.js", "content.js"],
      "css": ["floating-toolbar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open Page Copilot by Alon"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
